(copy_files ../*.*)
(alias (name runtest)
  (deps (alias runtest_config)))
; TEST FILE "callable_f.c"
(alias (name "callable_f.wtests")
  (deps (alias "callable_f.0.exec.wtests"))) ; to performs all sub-tests related to a file
(alias (name "callable_f.c")
  (deps (alias "callable_f.0.exec"))) ; to reproduce and visualize the all sub-test outputs related to a file
(rule ; TEST #0 OF TEST FILE tests/callable/callable_f.c
  (alias "callable_f.0.exec.wtests")
  (targets "callable_f.err.log" "callable_f.res.log"  )
  (deps "callable_f.0.exec.wtests" "../oracle/callable_f.res.oracle" "../oracle/callable_f.err.oracle"  "callable_f.c"  "extern_defs.h" "utils.h" "callable_spec.is" (package frama-c)  (package "frama-c-vernfr") (package "frama-c-wp") )
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (run frama-c-wtests -brief "callable_f.0.exec.wtests" "frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jamilon/Documents/vernfr/_build/default:.\" -load-plugin=vernfr,wp    callable_f.c  -vernfr -nfr-check-calls -main f_10ms -nfr-ispec callable_spec.is > \"callable_f.res.log\" 2> \"callable_f.err.log\"" ))
)
(rule ; REPRODUCE TEST #0 OF TEST FILE "callable_f.c"
  (alias "callable_f.0.exec")
  (deps  "callable_f.c"  "extern_defs.h" "utils.h" "callable_spec.is" (package frama-c)  (package "frama-c-vernfr") (package "frama-c-wp")  (universe))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (with-accepted-exit-codes 0 (system "frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jamilon/Documents/vernfr/_build/default:.\" -load-plugin=vernfr,wp    callable_f.c  -vernfr -nfr-check-calls -main f_10ms -nfr-ispec callable_spec.is")))
)
(rule ; SHOW TEST COMMAND #0 OF TEST FILE "callable_f.c"
  (alias "callable_f.0.exec.show")
  (deps  "callable_f.c"  "extern_defs.h" "utils.h" "callable_spec.is" (package frama-c)  (package "frama-c-vernfr") (package "frama-c-wp")  (universe))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (system "echo 'frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jamilon/Documents/vernfr/_build/default:.\" -load-plugin=vernfr,wp    callable_f.c  -vernfr -nfr-check-calls -main f_10ms -nfr-ispec callable_spec.is > \"callable_f.res.log\" 2> \"callable_f.err.log\"'"))
)
(rule
  (alias "callable_f.0.exec.diff")
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (diff "../oracle/callable_f.res.oracle" "callable_f.res.log"))
)
(rule
  (alias "callable_f.0.exec.diff")
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (diff "../oracle/callable_f.err.oracle" "callable_f.err.log"))
)
(alias (name "callable_f.diff")
  (deps (alias "callable_f.0.exec.diff"))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
)
(alias (name "runtest_config")
  (deps (alias "callable_f.diff"))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
)
