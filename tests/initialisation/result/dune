)
(rule ; SHOW TEST COMMAND #0 OF TEST FILE "initialisation.c"
  (alias "initialisation.0.exec.show")
  (deps  "initialisation.c"  "initialisation.is" (package frama-c)  (package "frama-c-vernfr")  (universe))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core}))
(action (system "echo 'frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jesper/Documents/opensandbox/vernfr/_build/default:.\" -load-plugin=vernfr    initialisation.c  -vernfr -nfr-proper-init -main f_10ms -nfr-ispec initialisation.is > \"initialisation.res.log\" 2> \"initialisation.err.log\"'"))
