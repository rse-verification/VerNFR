(copy_files ../*.*)
(alias (name ptests)
  (deps (alias ptests_config)))
; TEST FILE "tmon_b.c"
(alias (name "tmon_b.wtests")
  (deps (alias "tmon_b.0.exec.wtests"))) ; to performs all sub-tests related to a file
(alias (name "tmon_b.c")
  (deps (alias "tmon_b.0.exec"))) ; to reproduce and visualize the all sub-test outputs related to a file
(rule ; TEST #0 OF TEST FILE tests/isola2026/tmon_b.c
  (alias "tmon_b.0.exec.wtests")
  (targets "tmon_b.err.log" "tmon_b.res.log"  )
  (deps "tmon_b.0.exec.wtests" "../oracle/tmon_b.res.oracle" "../oracle/tmon_b.err.oracle"  "tmon_b.c"  "utils.h" "sensors.h" "warnings.h" "tmon.is" (package frama-c)  (package "frama-c-vernfr") (package "frama-c-wp") )
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (run frama-c-wtests -brief "tmon_b.0.exec.wtests" "frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jamilon/Documents/vernfr/_build/default:.\" -load-plugin=vernfr,wp    tmon_b.c  -vernfr -keep-unused-functions \"all\" -keep-unused-types -nfr-ispec tmon.is -nfr-check-calls -nfr-fun-ptrs -nfr-no-fun-defs -nfr-all-entries-defined -nfr-only-entries -nfr-static-vars -nfr-proper-init -nfr-check-ptr-literals -nfr-typedefs > \"tmon_b.res.log\" 2> \"tmon_b.err.log\"" ))
)
(rule ; REPRODUCE TEST #0 OF TEST FILE "tmon_b.c"
  (alias "tmon_b.0.exec")
  (deps  "tmon_b.c"  "utils.h" "sensors.h" "warnings.h" "tmon.is" (package frama-c)  (package "frama-c-vernfr") (package "frama-c-wp")  (universe))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (with-accepted-exit-codes 0 (system "frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jamilon/Documents/vernfr/_build/default:.\" -load-plugin=vernfr,wp    tmon_b.c  -vernfr -keep-unused-functions \"all\" -keep-unused-types -nfr-ispec tmon.is -nfr-check-calls -nfr-fun-ptrs -nfr-no-fun-defs -nfr-all-entries-defined -nfr-only-entries -nfr-static-vars -nfr-proper-init -nfr-check-ptr-literals -nfr-typedefs")))
)
(rule ; SHOW TEST COMMAND #0 OF TEST FILE "tmon_b.c"
  (alias "tmon_b.0.exec.show")
  (deps  "tmon_b.c"  "utils.h" "sensors.h" "warnings.h" "tmon.is" (package frama-c)  (package "frama-c-vernfr") (package "frama-c-wp")  (universe))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (system "echo 'frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jamilon/Documents/vernfr/_build/default:.\" -load-plugin=vernfr,wp    tmon_b.c  -vernfr -keep-unused-functions \"all\" -keep-unused-types -nfr-ispec tmon.is -nfr-check-calls -nfr-fun-ptrs -nfr-no-fun-defs -nfr-all-entries-defined -nfr-only-entries -nfr-static-vars -nfr-proper-init -nfr-check-ptr-literals -nfr-typedefs > \"tmon_b.res.log\" 2> \"tmon_b.err.log\"'"))
)
(rule
  (alias "tmon_b.0.exec.diff")
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (diff "../oracle/tmon_b.res.oracle" "tmon_b.res.log"))
)
(rule
  (alias "tmon_b.0.exec.diff")
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (diff "../oracle/tmon_b.err.oracle" "tmon_b.err.log"))
)
(alias (name "tmon_b.diff")
  (deps (alias "tmon_b.0.exec.diff"))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
)
(alias (name "ptests_config")
  (deps (alias "tmon_b.diff"))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
)
