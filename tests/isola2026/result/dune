; TEST FILE "utils.c"
(alias (name "utils.wtests")
  (deps (alias "utils.0.exec.wtests"))) ; to performs all sub-tests related to a file
(alias (name "utils.c")
  (deps (alias "utils.0.exec"))) ; to reproduce and visualize the all sub-test outputs related to a file
(rule ; TEST #0 OF TEST FILE tests/isola2026/utils.c
  (alias "utils.0.exec.wtests")
  (targets "utils.err.unfiltered-log" "utils.res.unfiltered-log"  )
  (deps "utils.0.exec.wtests" "../oracle/utils.res.oracle" "../oracle/utils.err.oracle"  "utils.c"  (package frama-c)  (package "frama-c-vernfr") (package "frama-c-wp") )
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (run frama-c-wtests -brief "utils.0.exec.wtests" "frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jamilon/Documents/vernfr/_build/default:.\" -load-plugin=vernfr,wp    utils.c -wp -wp-rte > \"utils.res.unfiltered-log\" 2> \"utils.err.unfiltered-log\""  "cat utils.res.unfiltered-log | sed -E 's/\\([0-9]+ms(-[0-9]+ms)*\\)//g' > \"utils.res.log\"" "cat utils.err.unfiltered-log | sed -E 's/\\([0-9]+ms(-[0-9]+ms)*\\)//g' > \"utils.err.log\""))
)
(rule ; FILTER RES #0 OF TEST FILE "utils.c"
  (deps "utils.res.unfiltered-log")
         (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (with-stdout-to "utils.res.log" (with-accepted-exit-codes (or 0 1 2 125) (system "cat utils.res.unfiltered-log | sed -E 's/\\([0-9]+ms(-[0-9]+ms)*\\)//g'"))))
)
(rule ; FILTER ERR #0 OF TEST FILE "utils.c"
  (deps "utils.err.unfiltered-log")
         (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (with-stdout-to "utils.err.log" (with-accepted-exit-codes (or 0 1 2 125) (system "cat utils.err.unfiltered-log | sed -E 's/\\([0-9]+ms(-[0-9]+ms)*\\)//g'"))))
)
(rule ; REPRODUCE TEST #0 OF TEST FILE "utils.c"
  (alias "utils.0.exec")
  (deps  "utils.c"  (package frama-c)  (package "frama-c-vernfr") (package "frama-c-wp")  (universe))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (with-accepted-exit-codes 0 (system "frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jamilon/Documents/vernfr/_build/default:.\" -load-plugin=vernfr,wp    utils.c -wp -wp-rte")))
)
(rule ; SHOW TEST COMMAND #0 OF TEST FILE "utils.c"
  (alias "utils.0.exec.show")
  (deps  "utils.c"  (package frama-c)  (package "frama-c-vernfr") (package "frama-c-wp")  (universe))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (system "echo 'frama-c -check -no-autoload-plugins -add-symbolic-path=\"/home/jamilon/Documents/vernfr/_build/default:.\" -load-plugin=vernfr,wp    utils.c -wp -wp-rte > \"utils.res.unfiltered-log\" 2> \"utils.err.unfiltered-log\"'"))
)
(rule
  (alias "utils.0.exec.diff")
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (diff "../oracle/utils.res.oracle" "utils.res.log"))
)
(rule
  (alias "utils.0.exec.diff")
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
(action (diff "../oracle/utils.err.oracle" "utils.err.log"))
)
(alias (name "utils.diff")
  (deps (alias "utils.0.exec.diff"))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
)
(alias (name "ptests_config")
  (deps (alias "utils.diff"))
  (enabled_if (and true %{lib-available:frama-c-vernfr.core} %{lib-available:frama-c-wp.core}))
)
(alias (name disabled_ptests)
  (deps (alias disabled_ptests_config)))
(alias (name ptests)
  (deps (alias disabled_ptests)))
(alias (name ptests_config)
  (deps (alias disabled_ptests_config)))
(rule ; Warns when some test conditions are disabled
  (alias disabled_ptests_config)
  (deps (universe))
  (enabled_if (or false  (not %{lib-available:frama-c-vernfr.core}) (not %{lib-available:frama-c-wp.core})))
  (action (progn (echo "WARNING: Enabling conditions of some tests are false for @tests/isola2026/ptests_config\n")
                 (echo "- \%{lib-available:frama-c-vernfr.core}: " %{lib-available:frama-c-vernfr.core} "\n")
                 (echo "- \%{lib-available:frama-c-wp.core}: " %{lib-available:frama-c-wp.core} "\n")
  ))
)

