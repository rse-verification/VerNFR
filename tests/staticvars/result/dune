  (alias "static.0.exec.wtests")
  (targets "static.err.log" "static.res.log"  )
  (deps "static.0.exec.wtests" "../oracle/static.res.oracle" "../oracle/static.err.oracle"  "static.c"  (package frama-c)  (package "frama-c-vernfr") )
